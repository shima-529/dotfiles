# hard-tab is necessary; C indent doesn't support this.
snippet main
	int main(int argc, char *argv[]) {
		${0:TARGET}
	}

snippet vmain
alias vm
	int main() {
		${0:TARGET}
	}

# #include <...>
snippet inc
alias   #inc, #include
    #include <${1:stdio}.h>${0}
# #include "..."
snippet inc2
alias   #inc2, #include2, incc
    #include "${1}.h"${0}
